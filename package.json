{
    "name": "banking-ai-dashboard-root",
    "private": true,
    "version": "0.1.0",
    "scripts": {
        "dev": "npm run dev --prefix frontend",
        "build": "npm run build --prefix frontend",
        "backend": "powershell -ExecutionPolicy Bypass -File backend\\run-all.ps1",
        "backend:stop": "powershell -ExecutionPolicy Bypass -File backend\\stop-all.ps1",
        "install:all": "npm install && npm install --prefix frontend && cd backend && python -m pip install -r requirements.txt"
    }
}